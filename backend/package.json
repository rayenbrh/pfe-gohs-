    "@types/swagger-ui-express": "^4.1.7",
    "@types/uuid": "^9.0.8",
    "nodemon": "^3.1.9",
    "rimraf": "^5.0.10",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
