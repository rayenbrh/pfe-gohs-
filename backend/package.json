    "test:auth": "tsx src/scripts/auth.test.ts",
    "test:vehicles": "tsx src/scripts/vehicles.test.ts",
    "test:reservations": "tsx src/scripts/reservations.test.ts",
    "test:management": "tsx src/scripts/management.test.ts",
    "test:payments": "tsx src/scripts/payments.test.ts",
    "test:maintenance-admin": "tsx src/scripts/maintenance-admin.test.ts",
    "test:upload-security": "tsx src/scripts/upload-security.test.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^7.2.0",
