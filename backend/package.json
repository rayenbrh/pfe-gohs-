{
  "name": "inova-ride-backend",
  "version": "1.0.0",
  "description": "Inova Ride REST API — Node.js + Express + MongoDB",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon",
    "seed": "tsx src/scripts/seed.ts",
