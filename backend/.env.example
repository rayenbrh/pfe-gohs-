# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/inova-ride

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_min_64_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_refresh_secret_too
JWT_REFRESH_EXPIRES_IN=30d

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP (use Brevo/Mailgun for production)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@inovaride.com
EMAIL_FROM_NAME=Inova Ride

# Konnect Payment
KONNECT_API_URL=https://api.konnect.network
KONNECT_API_KEY=
KONNECT_WALLET_ID=
KONNECT_WEBHOOK_SECRET=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info

# Seed script (optional overrides — defaults shown in src/scripts/seed.ts)
# SEED_SUPER_ADMIN_EMAIL=admin@inovaride.com
# SEED_SUPER_ADMIN_PASSWORD=Admin123!
# SEED_ADMIN_EMAIL=manager@inovaride.com
# SEED_ADMIN_PASSWORD=Admin123!
